skowronekstudio.pl {
	# Reverse proxy do aplikacji
	reverse_proxy site:3000

	# Nagłówki bezpieczeństwa
	header {
		# Zapobiega clickjackingowi
		X-Frame-Options "SAMEORIGIN"
		# Blokuje MIME sniffing
		X-Content-Type-Options "nosniff"
		# Wymusza HTTPS przez rok
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		# Kontrola referrers
		Referrer-Policy "strict-origin-when-cross-origin"
		# Usuwa nagłówek serwera
		-Server
	}

	# Rate limiting na panel admina (Caddy Enterprise lub plugin)
	# Jeśli używasz Caddy bez pluginu rate_limit — usuń ten blok
	# @admin path /admin*
	# rate_limit @admin 10r/m

	# Logi
	log {
		output file /data/logs/access.log {
			roll_size 10MB
			roll_keep 5
		}
	}
}
