# ─────────────────────────────────────────────
# Skopiuj jako .env i uzupełnij wartości:
#   cp .env.example .env
# ─────────────────────────────────────────────

# ── Baza danych (SQLite) ──────────────────────
# Ścieżka do pliku bazy SQLite — domyślnie ./data/payload.db
DATABASE_URI=file:./data/payload.db

# ── Payload ───────────────────────────────────
# Min. 32 znaki — sekret do podpisywania JWT i szyfrowania sesji
PAYLOAD_SECRET=zmien_na_min_32_znakowy_sekret_losowy

# ── Cron ──────────────────────────────────────
CRON_SECRET=zmien_na_losowy_sekret_cron

# ── URL aplikacji ─────────────────────────────
# Adres publiczny — zmień na swój IP lub domenę (z portem jeśli nie 80/443)
NEXT_PUBLIC_SITE_URL=http://TWOJ_IP_LUB_DOMENA:1000
NEXT_PUBLIC_SERVER_URL=http://TWOJ_IP_LUB_DOMENA:1000

# ── Cloudflare R2 / S3 (opcjonalne) ──────────
# Bez tych zmiennych pliki zapisywane są lokalnie w /app/uploads
# S3_ENDPOINT=https://TWOJE_ACCOUNT_ID.r2.cloudflarestorage.com
# S3_BUCKET=skowronekstudio
# S3_ACCESS_KEY_ID=twoj_access_key
# S3_SECRET_ACCESS_KEY=twoj_secret_key
# S3_REGION=auto

# ── Resend (email) — opcjonalne ───────────────
# Wymagane dopiero po weryfikacji domeny w resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=studio@skowronekstudio.pl

# ── Google Places (opinie) — opcjonalne ──────
# GOOGLE_PLACES_API_KEY=twoj_klucz_api
