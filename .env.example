# Database
DATABASE_URI=postgresql://user:password@localhost:5432/skowronekstudio

# Payload
PAYLOAD_SECRET=your-payload-secret-min-32-chars-here

# Cloudflare R2 / S3
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_BUCKET=skowronekstudio
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=auto

# Cron
CRON_SECRET=your-cron-secret

# Google Places API (opinie)
GOOGLE_PLACES_API_KEY=your-google-api-key

# SMTP (email)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@skowronekstudio.pl
SMTP_PASS=your-smtp-password
SMTP_FROM="Skowronek Studio <noreply@skowronekstudio.pl>"

# App
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://skowronekstudio.pl
