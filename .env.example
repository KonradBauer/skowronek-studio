# ─────────────────────────────────────────────
# Skopiuj jako .env i uzupełnij wartości:
#   cp .env.example .env
# ─────────────────────────────────────────────

# ── Baza danych ───────────────────────────────
# DB_PASSWORD używane przez docker-compose do stworzenia kontenera PostgreSQL.
# DATABASE_URI w Docker jest nadpisywane automatycznie (patrz docker-compose.yml),
# ale tu zostaw spójną wartość (te same dane co DB_PASSWORD).
DB_PASSWORD=zmien_na_silne_haslo
DATABASE_URI=postgresql://payload:zmien_na_silne_haslo@localhost:5432/skowronekstudio

# ── Payload ───────────────────────────────────
# Min. 32 znaki — sekret do podpisywania JWT i szyfrowania sesji
PAYLOAD_SECRET=zmien_na_min_32_znakowy_sekret_losowy

# ── Cron ──────────────────────────────────────
CRON_SECRET=zmien_na_losowy_sekret_cron

# ── URL aplikacji ─────────────────────────────
# Adres publiczny — wbudowywany w Next.js podczas docker compose build
NEXT_PUBLIC_SITE_URL=http://157.173.96.140:1000
NEXT_PUBLIC_SERVER_URL=http://157.173.96.140:1000

# ── Cloudflare R2 / S3 ────────────────────────
S3_ENDPOINT=https://TWOJE_ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET=skowronekstudio
S3_ACCESS_KEY_ID=twoj_access_key
S3_SECRET_ACCESS_KEY=twoj_secret_key
S3_REGION=auto

# ── Resend (email) — opcjonalne ───────────────
# Wymagane dopiero po weryfikacji domeny skowronekstudio.pl w resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=studio@skowronekstudio.pl

# ── Google Places (opinie) — opcjonalne ──────
# GOOGLE_PLACES_API_KEY=twoj_klucz_api
