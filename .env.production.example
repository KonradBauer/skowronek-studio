# ──────────────────────────────────────
# Bazy danych (unikalne hasla!)
# ──────────────────────────────────────
DB1_PASSWORD=zmien-na-silne-haslo-1
DB2_PASSWORD=zmien-na-silne-haslo-2

# ──────────────────────────────────────
# Site 1 - skowronekstudio.pl
# ──────────────────────────────────────
SITE1_PAYLOAD_SECRET=min-32-znaki-losowy-string-site1
SITE1_CRON_SECRET=losowy-secret-cron-1
SITE1_SMTP_USER=kontakt@skowronekstudio.pl
SITE1_SMTP_PASS=haslo-smtp-1
SITE1_SMTP_FROM="Skowronek Studio <kontakt@skowronekstudio.pl>"

# ──────────────────────────────────────
# Site 2 - rezonansstudio.pl
# ──────────────────────────────────────
SITE2_PAYLOAD_SECRET=min-32-znaki-losowy-string-site2
SITE2_CRON_SECRET=losowy-secret-cron-2
SITE2_SMTP_USER=kontakt@rezonansstudio.pl
SITE2_SMTP_PASS=haslo-smtp-2
SITE2_SMTP_FROM="Rezonans Studio <kontakt@rezonansstudio.pl>"

# ──────────────────────────────────────
# Wspolne
# ──────────────────────────────────────
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
GOOGLE_PLACES_API_KEY=twoj-klucz-api

# Storage - sciezka do duzego dysku Contabo (domyslnie /mnt/storage)
# Struktura: /mnt/storage/uploads/site1, /mnt/storage/uploads/site2, /mnt/storage/db/site1, /mnt/storage/db/site2
STORAGE_PATH=/mnt/storage
