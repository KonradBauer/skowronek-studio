# ──────────────────────────────────────
# Skopiuj jako .env w katalogu projektu na VPS
# Plik nigdy nie jest commitowany do gita
# ──────────────────────────────────────

# Baza danych
DB_PASSWORD=zmien-na-silne-haslo-min-32-znaki
DATABASE_URI=postgresql://payload:zmien-na-silne-haslo-min-32-znaki@localhost:5432/skowronekstudio

# Payload CMS
PAYLOAD_SECRET=min-32-znakowy-losowy-string
CRON_SECRET=losowy-secret-cron

# URLs — baked do buildu Next.js
# Zmienić na domenę gdy będzie gotowa
NEXT_PUBLIC_SITE_URL=http://157.173.96.140
NEXT_PUBLIC_SERVER_URL=http://157.173.96.140

# Cloudflare R2 / S3
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET=skowronekstudio
S3_ACCESS_KEY_ID=twoj-access-key
S3_SECRET_ACCESS_KEY=twoj-secret-key
S3_REGION=auto

# Mailing — Resend (opcjonalnie)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=studio@skowronekstudio.pl

# Google Reviews (opcjonalnie)
GOOGLE_PLACES_API_KEY=twoj-klucz-api
